{
  "entities": {
    "SystemState": {
      "title": "SystemState",
      "description": "Represents the state of a system at a specific point in time.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number", "description": "Unix timestamp of the state." },
        "value": { "type": "number", "description": "Primary efficiency or performance metric." },
        "drift": { "type": "number", "description": "Calculated drift from optimal state." },
        "uncertainty": { "type": "number", "description": "Level of uncertainty in the data." },
        "raw_data": { "type": "object", "description": "Raw data from external feeds." }
      },
      "required": ["timestamp", "value"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "A prediction generated by the AI engine.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number", "description": "When the prediction was made." },
        "prediction": { "type": "string", "description": "Textual prediction." },
        "action": { "type": "string", "description": "Recommended action." },
        "probability": { "type": "number", "description": "Confidence level." },
        "outcome": { "type": "string", "description": "Actual outcome (for learning)." },
        "reward": { "type": "number", "description": "Calculated reward for the prediction." }
      },
      "required": ["timestamp", "prediction", "action"]
    },
    "LearningWeights": {
      "title": "LearningWeights",
      "description": "Current weights used by the decision engine.",
      "type": "object",
      "properties": {
        "accuracy": { "type": "number" },
        "efficiency": { "type": "number" },
        "risk": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["accuracy", "efficiency", "risk"]
    }
  },
  "firestore": {
    "/systems/{industry}/states/{stateId}": {
      "schema": "SystemState",
      "description": "Historical states for a specific industry."
    },
    "/systems/{industry}/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Historical predictions for a specific industry."
    },
    "/systems/{industry}/weights/current": {
      "schema": "LearningWeights",
      "description": "Current learning weights for a specific industry."
    }
  }
}
