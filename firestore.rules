rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: systems/{industry}/states
    // Fields: timestamp (number), value (number), drift (number), uncertainty (number), raw_data (map)
    //
    // Collection: systems/{industry}/predictions
    // Fields: timestamp (number), prediction (string), action (string), probability (number), outcome (string), reward (number)
    //
    // Collection: systems/{industry}/weights
    // Fields: accuracy (number), efficiency (number), risk (number), updatedAt (number)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "timeismoneyinc2019@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidState(data) {
      return data.timestamp is number &&
             data.value is number &&
             data.drift is number &&
             data.uncertainty is number;
    }

    function isValidPrediction(data) {
      return data.timestamp is number &&
             data.prediction is string && data.prediction.size() < 2000 &&
             data.action is string && data.action.size() < 2000 &&
             data.probability is number;
    }

    function isValidWeights(data) {
      return data.accuracy is number &&
             data.efficiency is number &&
             data.risk is number;
    }

    function isValidUser(data) {
      return data.role is string && 
             data.role in ['user', 'guest'] && // Users cannot grant themselves admin
             data.email is string &&
             data.displayName is string;
    }

    function isIndustryAuthorized(industry) {
      return isAuthenticated() && 
             (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorizedIndustries.contains(industry));
    }

    // Rules
    match /systems/{industry} {
      match /states/{stateId} {
        allow read: if isIndustryAuthorized(industry);
        allow create: if isIndustryAuthorized(industry) && isValidState(request.resource.data);
      }
      match /predictions/{predictionId} {
        allow read: if isIndustryAuthorized(industry);
        allow create: if isIndustryAuthorized(industry) && isValidPrediction(request.resource.data);
        // Predictions are IMMUTABLE - no updates allowed
        allow update: if false;
      }
      match /weights/{weightId} {
        allow read: if isIndustryAuthorized(industry);
        allow write: if isAdmin(); // Only admins can tune the weights
      }
      match /decisions/{decisionId} {
        allow read: if isIndustryAuthorized(industry);
        allow create: if isIndustryAuthorized(industry);
        allow update: if false; // Decisions are IMMUTABLE
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Users can only update their profile, NOT their role or authorized industries
      allow write: if isAuthenticated() && request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'authorizedIndustries']);
    }

    match /test/connection {
      allow read: if true;
    }

    match /system/{docId} {
      // Allow authenticated users to read system state
      allow read: if isAuthenticated();
      // Only admins can update the baseline or current state
      allow write: if isAdmin();
    }
  }
}
